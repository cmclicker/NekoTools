{
  "name": "nekotools",
  "private": true,
  "version": "0.0.0",
  "description": "Local-only, air-gapped-capable, zero-telemetry suite of visual developer workbenches.",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "tsc -b",
    "offline-guard": "pnpm --filter @nekotools/offline-guard run scan",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}

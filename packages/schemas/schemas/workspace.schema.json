{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nekotools.local/workspace.schema.json",
  "title": "NekoTools Workspace",
  "type": "object",
  "required": [
    "version",
    "id",
    "toolId",
    "toolVersion",
    "createdAt",
    "updatedAt",
    "artifacts",
    "diagnostics"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "toolId": { "type": "string", "minLength": 1 },
    "toolVersion": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "artifact.schema.json" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "diagnostic.schema.json" }
    },
    "uiState": { "type": "object" },
    "notes": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nekotools.local/export.schema.json",
  "title": "NekoTools Exporter Descriptor",
  "type": "object",
  "required": [
    "version",
    "id",
    "toolId",
    "target",
    "accepts",
    "producesMimeType",
    "producesExtension"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "toolId": { "type": "string", "minLength": 1 },
    "target": { "enum": ["json", "markdown", "plaintext", "csv", "html", "binary"] },
    "accepts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "producesMimeType": { "type": "string", "minLength": 1 },
    "producesExtension": { "type": "string", "minLength": 1 }
  }
}
